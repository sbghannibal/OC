# Example environment file – copy to .env and fill in real values.
# The .env file must be placed at the repository root (one level above public/).
# Never commit the real .env to version control.

APP_ENV=production

# Base URL path – e.g. /OC/public for a sub-directory install.
# Leave empty for root-domain installs.
APP_BASE_PATH=/OC/public

# ── MySQL connection ──────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=admin_oc
DB_USERNAME=admin_oc
DB_PASSWORD=

# ── First admin user (used only by bin/create-user.php) ───────────────────────
# After running the seed script you can remove these lines or leave them;
# they are ignored once the users table already has at least one record.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production

# ── SEPA / EPC-QR payment details (optional) ─────────────────────────────────
SEPA_NAME=
SEPA_IBAN=
SEPA_BIC=

# ── QR registration link signing key ─────────────────────────────────────────
# Required for signed QR-code registration links (GET /events/{slug}/qr).
# Generate with: php -r "echo bin2hex(random_bytes(32));"
# Keep secret – never commit the real value.
APP_SIGNING_KEY=
